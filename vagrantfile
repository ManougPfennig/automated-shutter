Vagrant.configure("2") do |config|
	config.vm.box = "bento/debian-13" # https://portal.cloud.hashicorp.com/vagrant/discover/bento/debian-13
	config.vm.box_version = "202510.26.0"

	# Keeps the default insecure vagrant ssh key (local testing purposes only)
	config.ssh.insert_key = false

	config.vm.synced_folder ".", "/vagrant", disabled: true

	config.vm.hostname = "shutter"
	
	config.vm.provider "virtualbox" do |vb|
		vb.memory = 1024
		vb.cpus = 1
		vb.customize ["modifyvm", :id, "--usb", "off"] # Disables USB controller (can avoid launch errors)
	end

	config.vm.define "shutter" do |app|
		app.vm.hostname = "shutter.sandbox"
		config.vm.network "private_network", ip: "192.168.60.5" # Host-only network with static IP
	end
end
